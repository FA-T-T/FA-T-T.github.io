---
import BaseLayout from "@layouts/BaseLayout.astro";
import { formatEntryDate, loadMarkdownEntries, type MarkdownModule } from "../../lib/writing";

const posts = await loadMarkdownEntries(import.meta.glob<MarkdownModule>("../../content/blog/**/*.md"), "blog");
---

<BaseLayout title="博客" description="技术博客归档。" bodyClass="blog-page">
  <main class="terminal-main">
    <section class="terminal-window reveal">
      <header class="terminal-titlebar">
        <span></span>
        <span></span>
        <span></span>
        <strong>博客@everylink.site</strong>
      </header>
      <div class="terminal-body">
        <p class="terminal-line"><span>$</span> ls 文章</p>
        <h1>博客</h1>
        {
          posts.length > 0 ? (
            <div class="terminal-post-list">
              {posts.map((post) => (
                <a class="terminal-post" href={`/blog/${post.slug}/`}>
                  <span>{formatEntryDate(post.data.date)}</span>
                  <strong>{post.data.title}</strong>
                  <em>{post.data.description}</em>
                </a>
              ))}
            </div>
          ) : (
            <p>
              还没有公开的 Markdown 博客。把文章放到 <code>src/content/blog/</code> 后会显示在这里。
            </p>
          )
        }
        <p class="terminal-line"><span>$</span> cat ../../模板/内容模板.md</p>
        <a class="terminal-link" href="/projects/">打开项目</a>
      </div>
    </section>
  </main>
</BaseLayout>
