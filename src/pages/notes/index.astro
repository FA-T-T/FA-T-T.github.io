---
import BaseLayout from "@layouts/BaseLayout.astro";
import { formatEntryDate, loadMarkdownEntries, type MarkdownModule } from "../../lib/writing";

const notes = await loadMarkdownEntries(import.meta.glob<MarkdownModule>("../../content/notes/**/*.md"), "notes");
---

<BaseLayout title="笔记" description="研究笔记归档。" bodyClass="notes-page">
  <main class="paper-main">
    <article class="paper-sheet reveal">
      <p class="paper-kicker">笔记</p>
      <h1>研究笔记</h1>
      {
        notes.length > 0 ? (
          <div class="paper-note-list">
            {notes.map((note) => (
              <a class="paper-note" href={`/notes/${note.slug}/`}>
                <span>{formatEntryDate(note.data.date)}</span>
                <strong>{note.data.title}</strong>
                <em>{note.data.description}</em>
              </a>
            ))}
          </div>
        ) : (
          <>
            <p>
              目前还没有公开 Markdown 笔记。把文件加入 <code>src/content/notes/</code> 后，它们会出现在这里。
            </p>
            <p>
              这里的视觉语言更接近论文而不是仪表盘：窄行宽、安静留白、优先服务长文本阅读。
            </p>
          </>
        )
      }
    </article>
  </main>
</BaseLayout>
