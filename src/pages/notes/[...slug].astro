---
import BaseLayout from "@layouts/BaseLayout.astro";
import { formatEntryDate, loadMarkdownEntries, type MarkdownModule, type WritingEntry } from "../../lib/writing";

export async function getStaticPaths() {
  const notes = await loadMarkdownEntries(import.meta.glob<MarkdownModule>("../../content/notes/**/*.md"), "notes");
  return notes.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props as { entry: WritingEntry };
const Content = entry.Component;
const formattedDate = entry.data.date ? formatEntryDate(entry.data.date, "long") : "";
---

<BaseLayout title={entry.data.title} description={entry.data.description} bodyClass="notes-page" useMath={entry.data.use_math}>
  <main class="paper-main">
    <article class="paper-sheet paper-article reveal">
      <a class="back-link" href="/notes/">返回笔记</a>
      <p class="paper-kicker">Notes{formattedDate && ` / ${formattedDate}`}</p>
      <h1>{entry.data.title}</h1>
      {entry.data.deck && <p class="paper-deck">{entry.data.deck}</p>}
      <div class="article-meta-row">
        {entry.data.tags.map((tag) => <span class="meta-pill">{tag}</span>)}
      </div>
      <div class="paper-content">
        <Content />
      </div>
    </article>
  </main>
</BaseLayout>
